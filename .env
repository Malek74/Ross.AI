# Egyptian Civil-Code Contract Auditor — environment template
# Copy to .env and fill in your values.

# ─── OpenRouter (LLM + embeddings — one key covers both) ─────────────────────
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# ─── Model selection (runtime-swappable; leave as-is for defaults) ────────────
# Reasoning / audit LLM
LLM_MODEL=anthropic/claude-sonnet-4-5
# Cheap/fast model for the intake classifier
CLASSIFIER_MODEL=google/gemini-flash-1.5
# Embedding model — must stay the same across ALL domain indexes once built
EMBEDDING_MODEL=qwen/qwen3-embedding-8b

# ─── Retrieval settings ───────────────────────────────────────────────────────
# Max articles returned by search_statutes()
RETRIEVAL_TOP_K=8
# Max agent reasoning steps before forced finish
AGENT_MAX_STEPS=20

# ─── OpenRouter safety switches ───────────────────────────────────────────────
# Fall over to next provider on outage (prevents demo crash)
OPENROUTER_ALLOW_FALLBACKS=true
# Do NOT opt in to prompt logging on a legal-document tool
OPENROUTER_LOG_PROMPTS=false
